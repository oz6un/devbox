{
  "tui": "fullscreen",
  "theme": "dark",
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/mert/.local/bin/claude-notify",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/mert/.local/bin/claude-notify",
            "async": true
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/mert/.local/bin/claude-notify",
            "async": true
          }
        ]
      }
    ]
  }
}
