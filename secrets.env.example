# Copy to secrets.env (gitignored) and fill in. Every value stays local.

# Hetzner Cloud API token (project -> Security -> API tokens, read+write).
# Revoke it after provisioning — nothing needs it at runtime.
HCLOUD_TOKEN=

# Tailscale pre-auth key: https://login.tailscale.com/admin/settings/keys
# -> Generate auth key: Reusable OFF, Ephemeral OFF, Pre-approved ON.
# Single-use and short-lived; generate a fresh one per provision.
TS_AUTHKEY=

# Server identity/placement (defaults shown).
DEVBOX_NAME=devbox
DEV_USER=dev
SERVER_TYPE=cx23
LOCATION=fsn1
IMAGE=ubuntu-24.04

# Git identity written on the box.
GIT_NAME=
GIT_EMAIL=

# Pushover keys for Claude Code phone notifications (optional — leave empty
# to skip; get them at https://pushover.net after installing the app).
PUSHOVER_TOKEN=
PUSHOVER_USER=

# Claude Code user skills to install, space-separated git URLs (optional).
# CLAUDE_SKILLS="https://github.com/you/your-skill.git"
CLAUDE_SKILLS=

# Regex of ~/Code paths sync-code.sh should skip (optional).
# SYNC_EXCLUDE_RE="third-party-audits|scratch"
SYNC_EXCLUDE_RE=
